<?xml version="1.0" encoding="UTF-8"?>
<!--
  Chase H.Q. (chasehq) — Taito Z, 1988
  TC0100SCN tilemap, TC0040IOC I/O, 12 MHz CPUs (24 MHz XTAL / 2).
  Two OBJ ROM banks (foreground + background) totaling 4MB sprites.
  TC0150ROD road chip present on CPU B bus.

  NOTE: chasehq uses TC0100SCN tilemap and TC0040IOC I/O, not
  TC0480SCP/TC0510NIO. The current taito_z RTL targets dblaxle/racingb.
  This MRA is provided for catalog completeness; per-game parameters
  and chip variant selection are required for chasehq support.

  ROM names and CRCs are placeholders — replace with MAME ROM dump data.
  MAME set name: chasehq (Chase H.Q. / US version chasehq2)
-->
<misterromdescription>
  <name>Chase H.Q.</name>
  <setname>chasehq</setname>
  <rbf>taito_z</rbf>
  <mameversion>0245</mameversion>
  <year>1988</year>
  <manufacturer>Taito</manufacturer>
  <category>Racing</category>
  <buttons names="Brake,Gear,Start,Coin" default="A,B,Start,Select"/>

  <!-- CPU A + CPU B + Z80 program ROMs from MAME chasehq set -->
  <rom index="0" zip="chasehq.zip" type="merged" md5="None">
    <!-- CPU A (maincpu): 4x64KB -->
    <part name="b52-130.36" crc="4e7beb46" sha1="b8890c4a2121aa93cfc3a41ddbb3b840d0804cfa" offset="0x000000" length="0x020000"/>
