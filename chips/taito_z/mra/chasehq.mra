    <!-- CPU B (sub): 2x64KB -->
    <part name="b52-132.39" crc="a2f54789" sha1="941a6470e3a5ae35d079657260a8d7d6a9fca122" offset="0x080000" length="0x010000"/>
    <part name="b52-133.55" crc="12232f95" sha1="2894b95fc1d0a6e5b323bf3e7f1968f02b30a845" offset="0x090000" length="0x010000"/>
    <!-- Z80 (audiocpu) -->
    <part name="b52-137.51" crc="37abb74a" sha1="1feb1e49102c13a90e02c150472545cd9f6334da" offset="0x0C0000" length="0x010000"/>
  </rom>

