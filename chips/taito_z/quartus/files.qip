set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/jt12_pg_comb.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/jt12_pg_dt.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/jt12_pg_inc.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/jt12_pg_sum.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/jt12_pg.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/jt12_pm.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/jt12_reg_ch.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/jt12_reg.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/jt12_rst.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/jt12_sh_rst.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/jt12_sh.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/jt12_sh24.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/jt12_single_acc.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/jt12_sumch.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/jt12_timers.v
# ADPCM sub-module files
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/adpcm/jt10_adpcm_acc.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/adpcm/jt10_adpcm_cnt.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/adpcm/jt10_adpcm_comb.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/adpcm/jt10_adpcm_dbrom.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/adpcm/jt10_adpcm_div.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/adpcm/jt10_adpcm_drvA.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/adpcm/jt10_adpcm_drvB.v
set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/adpcm/jt10_adpcm_dt.v
