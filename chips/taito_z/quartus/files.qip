set_global_assignment -name VERILOG_FILE ../../../vendor/audio/jt12/adpcm/jt10_cen_burst.v

# =========================================================================
# TIMING CONSTRAINTS
# =========================================================================

set_global_assignment -name SDC_FILE taito_z.sdc

# =============================================================================
# END OF FILES.QIP
# =============================================================================
