<!--
    Batsugun (1993) — Toaplan
    MiSTer ROM descriptor for Toaplan V2 core

    Hardware:
      MC68000 @ 16 MHz
      NEC V25 @ 16 MHz (sound CPU — emulated as Z80 in this core for portability)
      GP9001 graphics processor
      YM2151 + OKI M6295 audio

    NOTE: Batsugun actually uses a NEC V25 (uPD70325) as its sound CPU, not a
    standard Z80. The V25 code is embedded in the main CPU ROM and the V25 accesses
    shared RAM at 0x80000–0xFFFFF. The Z80 sound CPU core in toaplan_v2.sv is
    provided for Toaplan V2 variants that use a standard Z80.
    For Batsugun: load the main CPU ROM at ioctl_index 0x00; the "Z80 ROM" slot
    (index 0x03) can be left empty or loaded with a V25-compatible stub.

    ROM set: batsugun (from MAME 0.251 / FBNeo)
    Parent: batsugun
    Manufacturer: Toaplan

    SDRAM layout:
      0x000000 – 0x07FFFF   512KB  CPU program ROM (tp030_1a.bin)
      0x100000 – 0x4FFFFF   4MB    GFX ROMs (tiles + sprites, interleaved by MAME loader)
      0x500000 – 0x53FFFF   256KB  ADPCM ROM (tp030_2.bin / MSM6295 sample data)
      0x600000 – 0x607FFF   32KB   Z80 sound ROM (ioctl_index 0x03, unused for Batsugun)

    CRCs below are from FBNeo d_batsugun.cpp (world set).
    Use: mame -romident batsugun  or  mame -listxml batsugun
-->

<misterromdescription>
    <name>Batsugun</name>
    <setname>batsugun</setname>
    <rbf>toaplan_v2</rbf>

    <!-- DIP switches — defaults from MAME batsugun driver -->
    <!-- Index 0xFE loaded as dsw[0] and dsw[1] in emu.sv -->
    <nvram index="2" size="2"/>

    <!-- Program ROM (68K CPU, index 0x00) -->
    <!-- SDRAM byte offset 0x000000 -->
    <rom index="0" zip="batsugun.zip" md5="None" type="merged">
        <!-- CPU program ROM — Batsugun (World), CRC from MAME 0.251 -->
        <part name="tp030_1a.bin" crc="cb1d4554" sha1="ef31f24d77e1c13bdf5558a04a6253e2e3e6a790"/>   <!-- 512KB -->
    </rom>

    <!-- GFX ROMs (tiles + sprites, index 0x01) -->
    <!-- SDRAM byte offset 0x100000 -->
    <!-- FBNeo loads as 4x 1MB planes: 3l+3h interleaved, 4l+4h interleaved, 5+6 -->
    <rom index="1" zip="batsugun.zip" md5="None" type="merged">
        <!-- GP9001 #0 tile data (4bpp, planes interleaved) -->
        <part name="tp030_3l.bin" crc="3024b793" sha1="e161db940f069279356fca2c5bf2753f07773705"/>   <!-- 1MB plane 0-lo -->
        <part name="tp030_3h.bin" crc="ed75730b" sha1="341f0f728144a049486d996c9bb14078578c6879"/>   <!-- 1MB plane 0-hi -->
        <part name="tp030_4l.bin" crc="fedb9861" sha1="4b0917056bd359b21935358c6bcc729262be6417"/>   <!-- 1MB plane 1-lo -->
        <part name="tp030_4h.bin" crc="d482948b" sha1="31be7dc5cff072403b783bf203b9805ffcad7284"/>   <!-- 1MB plane 1-hi -->
        <!-- GP9001 #1 tile data -->
        <part name="tp030_5.bin"  crc="bcf5ba05" sha1="40f98888a29cdd30cda5dfb60fdc667c69b0fdb0"/>   <!-- 1MB -->
        <part name="tp030_6.bin"  crc="0666fecd" sha1="aa8f921fc51590b5b05bbe0b0ad0cce5ff359c64"/>   <!-- 1MB -->
    </rom>

    <!-- ADPCM ROM (OKI M6295 sample data, index 0x02) -->
    <!-- SDRAM byte offset 0x500000 -->
    <rom index="2" zip="batsugun.zip" md5="None" type="merged">
        <part name="tp030_2.bin" crc="276146f5" sha1="bf11d1f6782cefcad77d52af4f7e6054a8f93440"/>    <!-- 256KB -->
    </rom>

    <!-- Z80 sound ROM slot (index 0x03) — unused for Batsugun (uses NEC V25) -->
    <!-- SDRAM byte offset 0x600000 — leave empty or omit for Batsugun -->
    <!-- Other Toaplan V2 games with a standard Z80 sound CPU load their Z80 ROM here -->

    <!-- DIP switch defaults (index 0xFE) -->
    <rom index="254">
        <!-- DSW1: difficulty, lives, etc. — all OFF = factory defaults -->
        <part>00 00</part>
    </rom>

</misterromdescription>
